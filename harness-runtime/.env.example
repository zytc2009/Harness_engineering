# ═══════════════════════════════════════════════════
# Harness Runtime — Multi-Provider Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════

# ── Provider Selection ─────────────────────────────
# Options: anthropic, openai, deepseek, kimi, qwen, glm, minimax, xiaomi, ollama, custom
PROVIDER=anthropic

# ── Anthropic (PROVIDER=anthropic) ─────────────────
ANTHROPIC_API_KEY=your_key_here
MAIN_MODEL=claude-sonnet-4-20250514
MEMORY_MODEL=claude-haiku-4-5-20251001

# ── OpenAI-Compatible Providers ────────────────────
# Used for: openai, deepseek, kimi, qwen, glm, minimax, xiaomi, ollama, custom
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# MAIN_MODEL=deepseek-chat
# MEMORY_MODEL=deepseek-chat

# ── Ollama (local models) ─────────────────────────
# PROVIDER=ollama
# MAIN_MODEL=gemma4:26b-a4b-it-q4_K_M
# MEMORY_MODEL=gemma4:26b-a4b-it-q4_K_M
# OPENAI_COMPATIBLE_API_KEY=ollama
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1

# ── Custom Provider (any OpenAI-compatible API) ───
# PROVIDER=custom
# OPENAI_COMPATIBLE_BASE_URL=https://your-api-endpoint/v1
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# MAIN_MODEL=your-model-name
# MEMORY_MODEL=your-model-name

# ── Per-Phase Provider Overrides (optional) ───────
# Each agent phase can use a different provider/model/key.
# Unset keys fall back to the global values above.
#
# Available per-phase vars for each PHASE (architect / implementer / tester):
#   {PHASE}_PROVIDER   — provider name
#   {PHASE}_MODEL      — model ID
#   {PHASE}_API_KEY    — API key (falls back to global key)
#   {PHASE}_BASE_URL   — base URL (falls back to built-in default or OPENAI_COMPATIBLE_BASE_URL)
#   {PHASE}_USER_AGENT — custom User-Agent header (see note below)
#
# Example: architect uses Claude (reasoning), implementer uses DeepSeek (cost), tester local
# ARCHITECT_PROVIDER=anthropic
# ARCHITECT_MODEL=claude-opus-4-6
# ARCHITECT_API_KEY=sk-ant-...
#
# IMPLEMENTER_PROVIDER=deepseek
# IMPLEMENTER_MODEL=deepseek-chat
# IMPLEMENTER_API_KEY=sk-...
# IMPLEMENTER_BASE_URL=https://api.deepseek.com   # optional, auto-resolved by provider
#
# TESTER_PROVIDER=ollama
# TESTER_MODEL=gemma4:26b-a4b-it-q4_K_M
# TESTER_BASE_URL=http://localhost:11434/v1

# ── User-Agent 伪装（高风险，非推荐）─────────────────
# 部分 API（如 Kimi For Coding）限制只允许特定客户端调用，
# 通过校验 User-Agent 实现。{PHASE}_USER_AGENT 可注入自定义 UA 绕过此限制。
#
# 推荐做法：优先申请无限制的标准 API Key（如 moonshot-v1-8k），避免使用 UA 伪装。
#
# 如确实只有受限 Key，可使用以下配置，但请知悉风险：
#   - 违反服务商 ToS，账号可能被封禁
#   - 服务商可能随时加强校验导致失效
#   - 不保证长期可用
#
# IMPLEMENTER_USER_AGENT=claude-code/1.0

# ── Harness Settings ──────────────────────────────
MAX_STEPS=60          # 全局安全兜底（所有 phase 合计上限）
MAX_RETRIES=3

# Per-phase 步数限制（超限后强制进入下一 phase，而非终止）
# 默认值：architect=10, implementer=25, tester=15
# ARCHITECT_MAX_STEPS=10
# IMPLEMENTER_MAX_STEPS=25
# TESTER_MAX_STEPS=15
