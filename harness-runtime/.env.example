# Harness Runtime - Example Configuration
# Copy this file to .env and fill in the values you need.

# Global provider selection
# Options: anthropic, openai, deepseek, kimi, qwen, glm, minimax, xiaomi, ollama, custom
PROVIDER=anthropic

# Global execution backend selection
# Options:
#   provider -> API-backed LangChain model invocation
#   cli      -> local CLI invocation, useful for tools such as codex without API keys
#
# Resolution priority:
#   task constraints > phase env vars > global env vars > runtime default
#
# EXECUTION_MODE=provider
# CLI_COMMAND=codex exec -c approval_mode=full-auto -o {output_file} -
# CLI_TIMEOUT=180
#
# Supported CLI placeholders:
#   {prompt_file}
#   {prompt_content}
#   {output_file}
#
# If no prompt placeholder is present, runtime sends the prompt via stdin.

# Anthropic
ANTHROPIC_API_KEY=your_key_here
MAIN_MODEL=claude-sonnet-4-20250514
MEMORY_MODEL=claude-haiku-4-5-20251001

# OpenAI-compatible providers
# Used for: openai, deepseek, kimi, qwen, glm, minimax, xiaomi, ollama, custom
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://your-api-endpoint/v1
# MAIN_MODEL=deepseek-chat
# MEMORY_MODEL=deepseek-chat

# Ollama example
# PROVIDER=ollama
# MAIN_MODEL=gemma4:26b-a4b-it-q4_K_M
# MEMORY_MODEL=gemma4:26b-a4b-it-q4_K_M
# OPENAI_COMPATIBLE_API_KEY=ollama
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1

# Custom provider example
# PROVIDER=custom
# OPENAI_COMPATIBLE_BASE_URL=https://your-api-endpoint/v1
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# MAIN_MODEL=your-model-name
# MEMORY_MODEL=your-model-name

# Per-phase overrides
# Available per-phase vars for architect / implementer / tester:
#   {PHASE}_EXECUTION_MODE
#   {PHASE}_CLI_COMMAND
#   {PHASE}_CLI_TIMEOUT
#   {PHASE}_PROVIDER
#   {PHASE}_MODEL
#   {PHASE}_API_KEY
#   {PHASE}_BASE_URL
#   {PHASE}_USER_AGENT
#
# Example: architect uses provider, implementer/tester use codex CLI
# ARCHITECT_EXECUTION_MODE=provider
# ARCHITECT_PROVIDER=deepseek
# ARCHITECT_MODEL=deepseek-reasoner
#
# IMPLEMENTER_EXECUTION_MODE=cli
# IMPLEMENTER_CLI_COMMAND=codex exec -c approval_mode=full-auto -o {output_file} -
# IMPLEMENTER_CLI_TIMEOUT=240
#
# TESTER_EXECUTION_MODE=cli
# TESTER_CLI_COMMAND=codex exec -c approval_mode=full-auto -o {output_file} -

# Optional User-Agent override for API providers that require a custom header
# IMPLEMENTER_USER_AGENT=claude-code/1.0

# Runtime settings
MAX_STEPS=60
MAX_RETRIES=3

# Default per-phase max steps: architect=10, implementer=25, tester=15
# ARCHITECT_MAX_STEPS=10
# IMPLEMENTER_MAX_STEPS=25
# TESTER_MAX_STEPS=15
